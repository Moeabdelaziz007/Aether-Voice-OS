{
    "name": "aether-web",
    "version": "0.1.0",
    "private": true,
    "scripts": {
        "dev": "next dev",
        "build": "next build",
        "analyze": "ANALYZE=true next build --webpack",
        "analyze:sm": "source-map-explorer .next/static/chunks/**/*.js",
        "analyze:static": "NEXT_BUNDLE_ANALYZER_LOG_DIR=.next/analyze-static npm run analyze",
        "start": "next start",
        "lint": "echo \"Linting skipped\"",
        "test": "vitest run",
        "test:watch": "vitest",
        "test:bench": "vitest run src/__tests__/benchmark.test.ts",
        "test:integration": "vitest run src/__tests__/geminiLive.integration.test.ts",
        "test:e2e": "playwright test",
        "test:e2e:ui": "playwright test --ui",
        "test:e2e:headed": "playwright test --headed",
        "test:e2e:debug": "playwright test --debug",
        "tauri": "tauri"
    },
    "dependencies": {
        "@ducanh2912/next-pwa": "^10.2.9",
        "@next/bundle-analyzer": "^16.1.6",
        "@react-three/drei": "^10.7.7",
        "@react-three/fiber": "^9.5.0",
        "@react-three/postprocessing": "^3.0.4",
        "@tauri-apps/plugin-global-shortcut": "^2.3.1",
        "@testing-library/user-event": "^14.6.1",
        "@types/three": "^0.183.1",
        "clsx": "^2.1.1",
        "concurrently": "^9.2.1",
        "firebase": "^12.10.0",
        "framer-motion": "^12.34.5",
        "lucide-react": "^0.575.0",
        "next": "15.1.6",
        "next-pwa": "^5.6.0",
        "postprocessing": "^6.38.3",
        "react": "19.0.0",
        "react-dom": "19.0.0",
        "sharp": "^0.33.5",
        "source-map-explorer": "^2.5.3",
        "tailwind-merge": "^3.5.0",
        "three": "^0.183.2",
        "tweetnacl": "^1.0.3",
        "zustand": "^5.0.11"
    },
    "devDependencies": {
        "@playwright/test": "^1.58.2",
        "@tailwindcss/postcss": "^4",
        "@tauri-apps/api": "^2.0.1",
        "@tauri-apps/cli": "^2.0.0-rc.18",
        "@testing-library/jest-dom": "^6.9.1",
        "@testing-library/react": "^16.3.2",
        "@types/node": "^20",
        "@types/react": "^19",
        "@types/react-dom": "^19",
        "eslint": "^9",
        "eslint-config-next": "16.1.6",
        "jsdom": "^28.1.0",
        "postcss": "^8",
        "tailwindcss": "^4",
        "typescript": "^5",
        "typescript-eslint": "^8.56.1",
        "vitest": "^4.0.18"
    }
