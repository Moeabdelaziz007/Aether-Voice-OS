# Required for Gemini Live Session
GOOGLE_API_KEY="your_google_api_key_here"
AETHER_JWT_SECRET="generate_a_secure_random_string"

# Required for Google Cloud Services and Firestore Logging
FIRESTORE_PROJECT="ancient-yeti-456601-g4"
GCP_SERVICE_KEY='{"type": "service_account", ...}'

# Required for Firebase Auth/Frontend config
NEXT_PUBLIC_FIREBASE_API_KEY="your_firebase_api_key_here"
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN="your_firebase_project.firebaseapp.com"
NEXT_PUBLIC_FIREBASE_PROJECT_ID="your_firebase_project_id"
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET="your_firebase_project.appspot.com"
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID="your_sender_id"
NEXT_PUBLIC_FIREBASE_APP_ID="your_app_id"
NEXT_PUBLIC_FIRESTORE_PROJECT="your_firebase_project_id"

# Optional config defaults
AETHER_ENV="development" # Set to 'production' for strict bounds
NEXT_PUBLIC_AETHER_GATEWAY_URL="ws://localhost:18789"
AETHER_JWT_SECRET="your_jwt_secret"
